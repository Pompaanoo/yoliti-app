# ─── Supabase ───────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe (PENDIENTE: el cliente aún no entrega credenciales) ─
# Rellenar cuando lleguen las llaves. Mientras tanto el flujo de
# pago corre en MODO STUB (no cobra, simula la inscripción).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
